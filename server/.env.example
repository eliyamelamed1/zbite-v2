NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/zbite
JWT_SECRET=your-jwt-secret-minimum-10-chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Persistent uploads directory — for Render.com, set to /var/data/uploads (Render Disk mount)
# Leave empty for local dev (defaults to ./uploads)
UPLOADS_DIR=

# Google OAuth — client ID is only needed in client/.env.development (VITE_GOOGLE_CLIENT_ID)
# The server verifies Google access tokens via Google's userinfo API — no client ID required

# Optional — enables pre-rendering for search engine bots (sign up at prerender.io)
PRERENDER_TOKEN=
